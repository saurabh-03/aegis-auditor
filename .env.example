# Aegis Auditor — environment configuration (copy to .env)

# HTTP server
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info

# Scan behavior
SCAN_TIMEOUT_MS=12000
USER_AGENT=AegisAuditor/0.1 (+https://example.com/aegis; defensive-security-scanner)

# Rate limiting (per client IP)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=20

# --- Phase 1+ (persistence & auth) ---
# DATABASE_URL=postgresql://aegis:aegis@localhost:5432/aegis?schema=public
# JWT_SECRET=change-me
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# --- Phase 2 (queue/workers) ---
# When REDIS_URL is set, scans run on a BullMQ queue processed by workers;
# otherwise they run in-process inside the API. WebSocket live progress works either way.
# REDIS_URL=redis://localhost:6379
# SCAN_CONCURRENCY=4
# AEGIS_ROLE controls whether a process runs the worker: "api" (no worker),
# "worker" (worker only), or unset (both — single-node default).
# AEGIS_ROLE=api

# --- Phase 3 (AI advisor) ---
# When ANTHROPIC_API_KEY is set, the AI Security Advisor uses Claude to write the
# executive summary and prioritized actions; otherwise a deterministic local
# advisor runs (always available, offline). Checklist/grouping/tickets are local.
# ANTHROPIC_API_KEY=
# AI_MODEL=claude-sonnet-5

# --- Phase 3 (dependency CVE intelligence) ---
# Where the Dependency Intelligence module sources CVEs for detected components:
#   both  (default) = live OSV.dev lookup merged with the offline dataset
#   osv            = OSV.dev only
#   local          = offline curated dataset only (no network; deterministic)
# OSV failures always degrade gracefully to the local dataset.
# CVE_SOURCE=both
# CVE_TIMEOUT_MS=6000

# --- Phase 3 (lab Core Web Vitals) ---
# The `webvitals` module measures real LCP/CLS/TBT/FCP + a resource waterfall
# using a headless browser. It requires Puppeteer, which is OPTIONAL:
#   npm run enable:browser      # == npm install puppeteer (downloads Chromium)
# Without Puppeteer the module emits an info finding and the scan still works.
# BROWSER_METRICS=auto          # auto (attempt) | off
# BROWSER_FORM_FACTOR=desktop   # desktop | mobile
# BROWSER_TIMEOUT_MS=30000

# --- Phase A (attack-surface crawler) ---
# The `spider` module crawls the site to map endpoints, parameters, and forms —
# the injectable surface active checks build on. It renders pages with Puppeteer
# when available (same optional dep as web-vitals) and falls back to an HTTP-only
# crawl otherwise. The crawl is shared (run once) across modules. Passive.
# CRAWL_MAX_PAGES=25
# CRAWL_MAX_DEPTH=3
# CRAWL_RESPECT_ROBOTS=true

# --- Phase B (Nuclei active DAST) ---
# The `nuclei` module runs the Nuclei engine's community CVE/misconfiguration
# templates against crawled endpoints. It is ACTIVE and authorization-gated:
# it only runs on an authorized scan (authorized && includeActive), which the
# project layer permits only after domain-ownership verification. Nuclei is an
# OPTIONAL external binary — if it isn't on PATH the module emits an info finding
# and the scan still completes. Install: https://github.com/projectdiscovery/nuclei
# NUCLEI_BIN=nuclei                       # binary name or absolute path
# NUCLEI_SEVERITIES=medium,high,critical  # severity floor sent to -severity
# NUCLEI_RATE_LIMIT=150                   # requests/sec cap
# NUCLEI_TIMEOUT_MS=180000                # hard kill timeout for the run
# NUCLEI_MAX_TARGETS=50                   # endpoints handed to Nuclei per scan
# NUCLEI_TEMPLATES=                       # comma-separated template files/dirs
#                                         # (-t); empty = Nuclei's default set

# --- Phase B (OWASP ZAP active DAST) ---
# The `zap` module drives an OWASP ZAP daemon to actively scan crawled endpoints
# (payload injection → XSS/SQLi/etc.). Also ACTIVE and authorization-gated. ZAP
# is optional external infrastructure — run it as a WORKER SIDECAR, never on the
# public API. If ZAP_API_URL is empty (default) the module emits an info finding;
# if it's set but the daemon is unreachable it degrades likewise. The daemon must
# stay cluster-internal — never expose it to the internet.
#   docker: ZAP_API_URL=http://zap:8080 docker compose --profile active up
#   k8s:    see k8s/zap.yaml (internal ClusterIP Service)
# ZAP_API_URL=                            # e.g. http://zap:8080 (empty = disabled)
# ZAP_API_KEY=aegis-zap                   # shared with the daemon's api.key
# ZAP_TIMEOUT_MS=300000                   # active-scan poll budget
# ZAP_MAX_SEED_URLS=100                   # endpoints seeded into ZAP's site tree

# --- Phase C (authenticated scans) ---
# Per-scan credentials (session cookie, bearer header, or an automated form-login
# username/password) are submitted with the scan request and required to have a
# VERIFIED project. They are NEVER written to the store or the report. With Redis,
# they're stashed under a short-TTL key (kept out of the retained BullMQ job) and
# read back by the worker; this bounds how long a credential can live in Redis.
# SCAN_SECRET_TTL_SEC=3600
# Form-login capture needs the optional browser engine (npm run enable:browser).

# --- Active finding replay (false-positive suppression) ---
# On an active scan, cheaply-verifiable findings (missing security headers,
# exposed .git/.env) are re-requested to confirm they still reproduce: confirmed
# issues are marked `confirmed`, and findings that no longer reproduce are demoted
# to an info note so they stop affecting the score. Injection findings are never
# auto-replayed (re-sending an attack payload is intrusive).
# REPLAY_ENABLED=true

# --- Monitoring: recurring scans & regression alerts ---
# The scheduler polls for due schedules and enqueues scans; on completion each
# project scan is diffed against the previous one and a regression raises a
# notification (+ optional webhook per schedule). Runs on the API node, not
# worker-only processes.
# SCHEDULER_ENABLED=on          # on | off
# SCHEDULER_INTERVAL_MS=60000

# --- Hardening for public / internet-facing deployments (see docs/DEPLOY-PUBLIC.md) ---
# SSRF protection is ON by default: scans of private/loopback/link-local/metadata
# targets are rejected. ONLY set this in local dev to scan localhost/LAN hosts.
# ALLOW_PRIVATE_TARGETS=1
# Require a signed-in user (or API key) for the public quick-scan endpoint.
# REQUIRE_AUTH_FOR_SCAN=1
